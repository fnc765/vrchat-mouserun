{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build exe (PyInstaller)",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\pyinstaller.exe",
      "args": [
        "main.py",
        "--onefile",
        "--noconsole",
        "--name",
        "vrchat-mouserun",
        "--hidden-import",
        "pynput.mouse._win32",
        "--hidden-import",
        "pynput.keyboard._win32"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
